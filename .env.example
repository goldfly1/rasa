# RASA Environment
# Copy to .env and fill in values. Never commit .env.

# --- LLM Providers ---
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama

# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# --- Databases ---
RASA_DB_HOST=localhost
RASA_DB_PORT=5432
RASA_DB_USER=postgres
RASA_DB_PASSWORD=8764

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- NATS ---
NATS_URL=nats://localhost:4222
NATS_JETSTREAM_DOMAIN=rasa

# --- Component specific ---
RASA_DATA_DIR=./data
RASA_LOG_LEVEL=INFO
RASA_CHECKPOINT_DIR=./data/archive

# --- Sandbox ---
RASA_SANDBOX_TIMEOUT=60
RASA_SANDBOX_TEMP_DIR=./data/sandbox

# --- Evaluation ---
RASA_EVAL_BENCHMARKS_DIR=./benchmarks

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=
